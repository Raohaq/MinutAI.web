@page
@model MinutAI.web.Pages.Meetings.HistoryModel
@{
    ViewData["Title"] = "Meeting History";
}

<div class="page-wrap">

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <div>
            <h1 class="hero-title mb-1" style="font-size:2.2rem;">Meeting History</h1>
            <p class="text-muted mb-0">View, download, or delete your previous meeting results.</p>
        </div>

        <div class="mt-2 mt-md-0">
            <a class="btn btn-brand" asp-page="/Index">Process New Meeting</a>
        </div>
    </div>

    <div class="card-soft p-4" style="width:100%; max-width:1600px; margin:0 auto;">
        @if (Model.Meetings == null || Model.Meetings.Count == 0)
        {
            <div class="text-muted">No meetings found yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width:180px;">Date</th>
                            <th style="width:260px;">Audio File</th>
                            <th>Summary Preview</th>
                            <th style="width:300px;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var m in Model.Meetings)
                        {
                            <tr>
                                <td class="text-nowrap">
                                    @m.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                </td>

                                <td class="text-truncate" style="max-width:260px;">
                                    @m.AudioFileName
                                </td>

                                <td>
                                    @Model.Preview(m.Summary)
                                </td>

                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a class="btn btn-sm btn-outline-brand"
                                           asp-page="/Meetings/Result"
                                           asp-route-id="@m.Id">
                                            View
                                        </a>

                                        <a class="btn btn-sm btn-outline-success"
                                           asp-page="/Meetings/History"
                                           asp-route-id="@m.Id"
                                           asp-page-handler="DownloadZip">
                                            Download ZIP
                                        </a>

                                        <!-- Delete button triggers modal -->
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-id="@m.Id"
                                                data-file="@m.AudioFileName"
                                                data-date="@m.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")">
                                            Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="text-muted small mt-3">
                Tip: Use “Download ZIP” to export transcript, summary, and action items together.
            </div>
        }
    </div>

</div>

<!-- ✅ Bootstrap Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <p class="mb-2">Are you sure you want to delete this meeting?</p>
                <div class="small text-muted">
                    <div><b>Date:</b> <span id="delDate"></span></div>
                    <div><b>File:</b> <span id="delFile"></span></div>
                </div>
                <p class="mt-3 mb-0 text-danger small">
                    This action cannot be undone.
                </p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>

                <form method="post" asp-page-handler="Delete" class="m-0">
                    <input type="hidden" name="id" id="delId" value="" />
                    <button type="submit" class="btn btn-danger">
                        Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Fill modal with the selected meeting details
        const deleteModal = document.getElementById('deleteModal');

        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;

            const id = button.getAttribute('data-id');
            const file = button.getAttribute('data-file');
            const date = button.getAttribute('data-date');

            document.getElementById('delId').value = id;
            document.getElementById('delFile').innerText = file;
            document.getElementById('delDate').innerText = date;
        });
    </script>
}