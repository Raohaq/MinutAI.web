@page
@model MinutAI.web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
    ViewData["BodyClass"] = "auth-page";
}

<div class="auth-wrap">
    <div class="auth-card">
        <img src="~/images/MinutAI logo.png" class="auth-logo" alt="MinutAI Logo" loading="lazy" />

        <h2 class="auth-title">Create account</h2>
        <p class="text-center text-muted mb-4">Create your account to start summarising meetings.</p>

        <form method="post">
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input asp-for="FullName" class="form-control" placeholder="Your name" />
                <span class="text-danger small" asp-validation-for="FullName"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <span class="text-danger small" asp-validation-for="Email"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Create a password" />
                <span class="text-danger small" asp-validation-for="Password"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Repeat password" />
                <span class="text-danger small" asp-validation-for="ConfirmPassword"></span>
            </div>

            @if (Model.ErrorMessage != null)
            {
                <div class="alert alert-danger py-2">
                    @Model.ErrorMessage
                </div>
            }

            <button type="submit" class="btn btn-brand w-100">
                <i class="bi bi-person-plus me-1"></i> Register
            </button>
        </form>

        <div class="text-center mt-3">
            <span class="text-muted">Already have an account?</span>
            <a asp-page="/Account/Login" class="fw-semibold">Login</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}