<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MinutAI</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="@(ViewData["BodyClass"] ?? "")">

    @* Show the teal header on all pages EXCEPT auth pages *@
    @if ((ViewData["BodyClass"] as string) != "auth-page")
    {
        <header class="app-header">
            <nav class="navbar navbar-expand-lg navbar-dark">
                @* container-fluid makes logo + content align to the left edge *@
                <div class="container-fluid px-4">
                    <a class="navbar-brand d-flex align-items-center" asp-page="/Index">
                        <img src="~/images/MinutAI logo.png" class="brand-logo" alt="MinutAI" />
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav"
                            aria-controls="nav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="nav">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Index">
                                    Upload
                                </a>
                            </li>

                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Meetings/History">
                                        History
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Privacy">
                                    Privacy
                                </a>
                            </li>
                        </ul>

                        <div class="d-flex gap-2">
                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <form method="post" asp-page="/Account/Logout" class="m-0">
                                    <button type="submit" class="btn btn-outline-light btn-sm">
                                        <i class="bi bi-box-arrow-right me-1"></i> Logout
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-outline-light btn-sm" asp-page="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Login
                                </a>
                                <a class="btn btn-light btn-sm text-dark" asp-page="/Account/Register">
                                    <i class="bi bi-person-plus me-1"></i> Register
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </nav>
        </header>
    }

    @* Page content *@
    @if ((ViewData["BodyClass"] as string) == "auth-page")
    {
        @RenderBody()
    }
    else
    {
        @* container-fluid so content can be wider; page-wrap still controls max width *@
        <div class="container-fluid px-4 py-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted">
            @* footer at bottom-left *@
            <div class="container-fluid px-4 py-3">
                &copy; 2026 - MinutAI - <a asp-page="/Privacy">Privacy</a>
            </div>
        </footer>
    }

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>